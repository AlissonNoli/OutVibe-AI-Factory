    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const projetoId = $('Supabase — criar projeto').first().json.id;\nconst brief = $('Code — validar auth + body').first().json.brief;\nconst n = $input.all().length;\n\nreturn [{\n  json: {\n    ok: true,\n    projeto_id: projetoId,\n    brief,\n    ficheiros: n,\n    mensagem: `Projecto ingerido com ${n} foto(s). O Diretor (02) pode processar estado=ingerido.`\n  }\n}];"
      },

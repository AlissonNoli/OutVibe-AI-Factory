      },
      "id": "supa-projeto",
      "name": "Supabase — criar projeto",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [760, 0],
      "notesInFlow": true,
      "notes": "Credencial Supabase OutVibe. origem=dashboard."
    },
    {
      "parameters": {
        "jsCode": "const projeto = $('Supabase — criar projeto').first().json;\nconst validated = $('Code — validar auth + body').first().json;\nconst projetoId = projeto.id;\n\nreturn validated.files.map((f) => ({\n  json: {\n    projeto_id: projetoId,\n    brief: validated.brief,\n    pasta_drive_id: validated.pasta_drive_id,\n    nome: f.nome,\n    mimeType: f.mimeType,\n    dataBase64: f.dataBase64\n  }\n}));"
      },
      "id": "code-expand",
      "name": "Code — expandir ficheiros",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 0]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map((item) => {\n  const { nome, mimeType, dataBase64, ...rest } = item.json;\n  return {\n    json: {\n      ...rest,\n      nome,\n      mimeType,\n      tipo: 'foto'\n    },\n    binary: {\n      data: {\n        data: dataBase64,\n        mimeType,\n        fileName: nome,\n        fileExtension: (nome.split('.').pop() || 'jpg').toLowerCase()\n      }\n    }\n  };\n});"
      },
      "id": "code-binary",
      "name": "Code — base64 → binary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1240, 0]

{
  "name": "00 — Ingestão (Dashboard → Supabase + Drive)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "outvibe-ingest",
        "responseMode": "responseNode",
        "options": {
          "rawBody": false
        }
      },
      "id": "webhook-ingest",
      "name": "Webhook — ingest dashboard",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "outvibe-ingest",
      "notesInFlow": true,
      "notes": "POST JSON { brief, files:[{name,mimeType,data}] }. Auth: Header Authorization Bearer = DASHBOARD_INGEST_TOKEN. Production URL: https://n8n.SEU_DOMINIO/webhook/outvibe-ingest"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst headers = item.headers || {};\nconst auth = String(headers.authorization || headers.Authorization || '').trim();\nconst expected = String($env.DASHBOARD_INGEST_TOKEN || '').trim();\n\nif (!expected) {\n  return [{\n    json: {\n      ok: false,\n      status: 503,\n      error: 'DASHBOARD_INGEST_TOKEN não definido no ambiente n8n (ver N8N_BLOCK_ENV_ACCESS_IN_NODE=false)'\n    }\n  }];\n}\n\nif (auth !== `Bearer ${expected}`) {\n  return [{\n    json: {\n      ok: false,\n      status: 401,\n      error: 'unauthorized'\n    }\n  }];\n}\n\nconst body = item.body && typeof item.body === 'object' ? item.body : item;\nconst brief = String(body.brief || '').trim();\nconst files = Array.isArray(body.files) ? body.files : [];\n\nif (!brief) {\n  return [{\n    json: {\n      ok: false,\n      status: 400,\n      error: 'brief obrigatório'\n    }\n  }];\n}\n\nconst images = files.filter((f) => {\n  const mime = String(f.mimeType || f.mime || '');\n  const data = String(f.data || f.dataBase64 || '');\n  return mime.startsWith('image/') && data.length > 0 && f.name;\n}).map((f) => ({\n  nome: String(f.name).slice(0, 180),\n  mimeType: String(f.mimeType || f.mime),\n  dataBase64: String(f.data || f.dataBase64).replace(/^data:[^;]+;base64,/, '')\n}));\n\nif (!images.length) {\n  return [{\n    json: {\n      ok: false,\n      status: 400,\n      error: 'pelo menos 1 imagem é obrigatória'\n    }\n  }];\n}\n\nif (images.length > 10) {\n  return [{\n    json: {\n      ok: false,\n      status: 400,\n      error: 'máximo 10 imagens por projecto'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ok: true,\n    brief,\n    files: images,\n    pasta_drive_id: '1RiQ5JMJASZnG4bOeghOfJTjUpqDXHQBF'\n  }\n}];"
      },
      "id": "code-validate",
      "name": "Code — validar auth + body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 0]
    },

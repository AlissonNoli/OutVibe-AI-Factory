      "id": "set-sem-foto",
      "name": "Set — sem foto",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1720,
        40
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $input.first().json;\nconst system = \"# Agente Copywriter \\u2014 v0.1\\n\\n## Papel\\n\\u00c9s o Agente Copywriter da OutVibe. Recebes o plano do Diretor e produzes o texto-m\\u00e3e de cada conte\\u00fado. Nunca publicas e nunca adaptas por plataforma \\u2014 isso \\u00e9 o Agente Social Media.\\n\\n## Sa\\u00edda\\nDevolve APENAS JSON (sem markdown) com:\\nprojeto_id, agente=\\\"copywriter\\\", status (\\\"ok\\\"|\\\"erro\\\"|\\\"precisa_revisao\\\"),\\nresultado.conteudos[] com: tipo, hook, corpo, cta, hashtags_semente[], texto_alternativo_foto,\\nqualidade (inteiro 0-100), problemas[], proximo_agente=\\\"social_media\\\"\\n\\n## Regras\\n1. Hook primeiro. Se o hook n\\u00e3o prende, o resto n\\u00e3o existe.\\n2. Escreve como se falasses com UMA pessoa.\\n3. Zero clich\\u00e9s de fitness.\\n4. Frases curtas. Cortar 20%.\\n5. Sem promessas de resultados garantidos.\\n6. status DEVE ser exactamente ok | erro | precisa_revisao (nunca \\\"completo\\\").\\n7. qualidade \\u00e9 inteiro 0-100, n\\u00e3o objeto.\\n8. Produz um texto-m\\u00e3e por item do plano_de_conteudos do Diretor (m\\u00e1x 5).\\n9. Usa o projeto_id exacto fornecido.\";\n\nconst userText = [\n  'Com base no plano do Diretor abaixo, produz os textos-mãe. Devolve APENAS JSON.',\n  '',\n  'projeto_id: ' + ctx.projeto_id,\n  'brief: ' + (ctx.brief || ''),\n  'arquivos: ' + JSON.stringify(ctx.arquivos || []),\n  ctx.foto_nome ? ('foto_principal: ' + ctx.foto_nome) : 'foto_principal: nenhuma',\n  '',\n  'plano_do_diretor:',\n  JSON.stringify(ctx.plano || {}, null, 2),\n  '',\n  'Se houver imagem em anexo, usa-a para escrever com especificidade visual.'\n].join('\\n');\n\nconst content = [];\nif (ctx.imageBlock) content.push(ctx.imageBlock);\ncontent.push({ type: 'text', text: userText });\n\nconst body = {\n  model: 'claude-sonnet-4-5',\n  max_tokens: 8192,\n  system,\n  messages: [{ role: 'user', content }]\n};\n\nreturn [{ json: { projeto_id: ctx.projeto_id, anthropicBody: body } }];"
      },

      "id": "http-claude",
      "name": "HTTP — Claude (Copywriter)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2440,
        -80
      ],
      "notesInFlow": true,
      "notes": "Credencial Anthropic. Modelo no Code — prompt Copywriter."
    },
    {
      "parameters": {
        "jsCode": "const projetoId = $('Code — prompt Copywriter').item.json.projeto_id;\nconst resp = $input.first().json;\n\nconst text = (resp.content || [])\n  .filter(b => b.type === 'text')\n  .map(b => b.text)\n  .join('\\n')\n  .trim();\n\nlet parsed;\ntry {\n  const cleaned = text.replace(/^```json\\s*/i, '').replace(/```$/i, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {\n    projeto_id: projetoId,\n    agente: 'copywriter',\n    status: 'erro',\n    resultado: { conteudos: [] },\n    qualidade: 0,\n    problemas: ['JSON inválido: ' + e.message, text.slice(0, 500)],\n    proximo_agente: null\n  };\n}\n\nparsed.projeto_id = parsed.projeto_id || projetoId;\nparsed.agente = 'copywriter';\n\nconst raw = String(parsed.status || '').toLowerCase().trim();\nconst okAliases = new Set(['ok', 'completo', 'complete', 'success', 'sucesso', 'done']);\nconst reviewAliases = new Set(['precisa_revisao', 'revisao', 'review', 'needs_review']);\nif (okAliases.has(raw)) parsed.status = 'ok';\nelse if (reviewAliases.has(raw)) parsed.status = 'precisa_revisao';\nelse if (['erro', 'error', 'fail', 'failed'].includes(raw)) parsed.status = 'erro';\nelse if (parsed.resultado && Array.isArray(parsed.resultado.conteudos) && parsed.resultado.conteudos.length) {\n  parsed.status = 'ok';\n} else {\n  parsed.status = 'erro';\n}\n\nif (parsed.qualidade && typeof parsed.qualidade === 'object') {\n  const n = Number(parsed.qualidade.nota);\n  parsed.qualidade = Number.isFinite(n) ? Math.round(n * (n <= 10 ? 10 : 1)) : 0;\n}\n\nconst estado = parsed.status === 'ok' ? 'escrito' : 'erro';\nconst conteudos = (parsed.resultado && parsed.resultado.conteudos) ? parsed.resultado.conteudos : [];\n\nreturn [{\n  json: {\n    projeto_id: projetoId,\n    estado,\n    saida: parsed,\n    conteudos,\n    status_agente: parsed.status,\n    mensagem_log: parsed.status === 'ok'\n      ? ('Copywriter: ' + conteudos.length + ' texto(s)-mãe')\n      : ('Copywriter: ' + parsed.status)\n  }\n}];"
      },
      "id": "code-parse",
      "name": "Code — parse copy JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2680,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "const base = $input.first().json;\nconst rows = [];\n\nif (base.status_agente === 'ok' && base.conteudos.length) {\n  for (const c of base.conteudos) {\n    rows.push({\n      json: {\n        projeto_id: base.projeto_id,\n        estado: base.estado,\n        status_agente: base.status_agente,\n        mensagem_log: base.mensagem_log,\n        saida: base.saida,\n        insert_mode: 'conteudo',\n        agente: 'copywriter',\n        tipo: c.tipo || 'post_instagram',\n        conteudo: c,\n        versao_prompt: 'copywriter-v0.1'\n      }\n    });\n  }\n}\n\n// always one update+log marker at end\nrows.push({\n  json: {\n    projeto_id: base.projeto_id,\n    estado: base.estado,\n    status_agente: base.status_agente,\n    mensagem_log: base.mensagem_log,\n    saida: base.saida,\n    insert_mode: 'finalizar',\n    agente: 'copywriter',\n    tipo: 'lote',\n    conteudo: base.saida,\n    versao_prompt: 'copywriter-v0.1'\n  }\n});\n\nreturn rows;"
      },

# ── VPS / n8n ────────────────────────────────────────────
# Subdomínio apontado para o IP do VPS (registo A no DNS)
N8N_DOMAIN=n8n.outvibe.pt

# Gerar com: openssl rand -hex 32  (NUNCA mudar depois do 1.º arranque)
N8N_ENCRYPTION_KEY=

# ── Postgres interno do n8n ─────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=

# ── Referência (configurar dentro do n8n, não aqui) ─────
# ANTHROPIC_API_KEY=      -> credencial "Anthropic" no n8n
# SUPABASE_URL=           -> credencial "Supabase" no n8n
# SUPABASE_SERVICE_KEY=   -> credencial "Supabase" no n8n
# GOOGLE_DRIVE            -> credencial OAuth2 no n8n

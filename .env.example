# ── VPS / n8n (único sítio de secrets na máquina) ───────
# Guia: docs/setup/04-vps-secrets.md
#
# Anthropic / Google Drive / Supabase NÃO vão aqui —
# configuram-se em n8n → Credentials (encriptadas com N8N_ENCRYPTION_KEY).

# Subdomínio apontado para o IP do VPS (registo A no DNS)
N8N_DOMAIN=n8n.outvibe.pt

# Gerar na VPS: openssl rand -hex 32
# NUNCA mudar depois do 1.º arranque — perdê-la = recriar todas as Credentials
N8N_ENCRYPTION_KEY=

# ── Postgres interno do n8n (não é o Supabase) ──────────
POSTGRES_USER=n8n
# Gerar na VPS: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── APIs externas → UI do n8n, não este ficheiro ────────
# Anthropic OutVibe     → tipo Anthropic
# Google Drive OutVibe  → OAuth2 (Client ID/Secret + Connect)
# Supabase OutVibe      → Header Auth / nó Supabase (service_role)

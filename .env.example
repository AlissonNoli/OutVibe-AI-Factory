# ── VPS / n8n (único sítio de secrets na máquina) ───────
# Guia: docs/setup/04-vps-secrets.md + docs/setup/12-dashboard-online.md
#
# Anthropic / Google Drive OAuth → Credentials no n8n (não aqui).
# Supabase service_role → aqui (dashboard) E também Credential no n8n.

# Subdomínios (registos A no DNS → IP da VPS)
N8N_DOMAIN=n8n.outvibe.pt
DASHBOARD_DOMAIN=publish.outvibe.pt

# Gerar na VPS: openssl rand -hex 32
# NUNCA mudar depois do 1.º arranque — perdê-la = recriar todas as Credentials
N8N_ENCRYPTION_KEY=

# ── Postgres interno do n8n (não é o Supabase) ──────────
POSTGRES_USER=n8n
# Gerar na VPS: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Dashboard (UI + ingestão) ───────────────────────────
DASHBOARD_PASSWORD=
# Mesmo token no contentor n8n (workflow 00) e no dashboard
DASHBOARD_INGEST_TOKEN=
SUPABASE_URL=https://axqefepwkjszyfdxiwwb.supabase.co
SUPABASE_SERVICE_KEY=
# URL production do webhook 00 (após activar o workflow)
N8N_INGEST_WEBHOOK_URL=https://n8n.outvibe.pt/webhook/outvibe-ingest

# ── APIs externas → UI do n8n ───────────────────────────
# Anthropic OutVibe     → tipo Anthropic
# Google Drive OutVibe  → OAuth2 (Client ID/Secret + Connect)
# Supabase OutVibe      → nó Supabase / Header Auth (service_role)
